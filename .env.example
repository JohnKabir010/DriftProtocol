# ── Shared ─────────────────────────────────────────────────────
NODE_ENV=development

# ── Database / Cache ───────────────────────────────────────────
DATABASE_URL=postgresql://drift:drift_dev@localhost:5432/drift
REDIS_URL=redis://localhost:6379

# ── API (apps/api) ─────────────────────────────────────────────
API_PORT=4000
JWT_ACCESS_SECRET=change-me-dev-only
JWT_REFRESH_SECRET=change-me-too-dev-only
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
DISCORD_OAUTH_CLIENT_ID=
DISCORD_OAUTH_CLIENT_SECRET=

# ── Realtime (apps/realtime) ───────────────────────────────────
REALTIME_PORT=2567
# Service token the realtime fleet uses to post race results to the API
REALTIME_SERVICE_TOKEN=change-me-service-token

# ── Web (apps/web) ─────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_REALTIME_URL=ws://localhost:2567

# ── Stellar (testnet first; gameplay never touches these) ──────
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
# Oracle/treasury signing keys live in KMS in prod; dev-only raw secrets here
STELLAR_ORACLE_SECRET=
USDC_ASSET_CONTRACT_ID=
MARKETPLACE_ESCROW_CONTRACT_ID=
TOURNAMENT_POOL_CONTRACT_ID=
ASSET_REGISTRY_CONTRACT_ID=
