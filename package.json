{
  "name": "drift-protocol",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "db:migrate": "pnpm --filter @drift/api prisma migrate dev",
    "db:studio": "pnpm --filter @drift/api prisma studio",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "contracts:bootstrap": "pnpm tsx scripts/testnet-bootstrap.ts",
    "contracts:deploy": "pnpm tsx scripts/deploy-marketplace-escrow.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "turbo run clean",
    "db:reset": "pnpm --filter @drift/api prisma migrate reset --force",
    "db:seed": "pnpm --filter @drift/api prisma db seed",
    "test:coverage": "turbo run test -- --coverage",
    "test:watch": "turbo run test -- --watch"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.6.3",
    "prettier": "^3.3.3"
  }
}
