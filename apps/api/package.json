  "devDependencies": {
    "@nestjs/cli": "^10.4.5",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.0",
    "@types/helmet": "^4.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.9.0",
    "@types/passport-google-oauth20": "^2.0.16",
    "@types/passport-jwt": "^4.0.1",
    "@types/pino-http": "^6.1.0",
    "jest": "^29.7.0",
    "prisma": "^5.22.0",
    "ts-jest": "^29.4.11",
    "ts-loader": "^9.6.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3",
    "webpack-node-externals": "^3.0.0"
  }
